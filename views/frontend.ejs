<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Matschema Frontend</title>
    <script>
      (function () {
        const saved = localStorage.getItem('matschema-theme');
        const theme = saved || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="frontend-body">
    <main class="frontend-page">
      <header class="frontend-hero">
        <div>
          <p class="frontend-eyebrow">Måltidsplanering</p>
          <h1>Matschema <span class="app-version">v3</span></h1>
          <p class="frontend-lead">Tre veckor visas alltid: innevarande vecka och två kommande. Klicka på en måltid för att se ingredienser.</p>
        </div>
        <div class="actions">
          <button type="button" id="themeToggle" class="button secondary frontend-theme-toggle" aria-label="Byt färgtema">🌙 Mörkt läge</button>
          <a class="button frontend-admin-button" href="/auth/login">Admin</a>
        </div>
      </header>

      <section class="frontend-weeks-grid">
        <% weeks.forEach(function(week, weekIndex) { %>
          <article class="frontend-week-card <%= weekIndex === 0 ? 'frontend-week-current' : '' %>">
            <div class="frontend-week-head">
              <h2>Vecka <%= week.weekNumber %></h2>
              <% if (weekIndex === 0) { %>
                <span class="frontend-pill">Nuvarande</span>
              <% } %>
            </div>

            <ul class="frontend-day-list">
              <% week.entries.forEach(function(entry) { %>
                <li class="frontend-day-item">
                  <span class="frontend-day-name"><%= entry.day %></span>
                  <span class="frontend-meal-wrap">
                    <% if (entry.ingredients && entry.ingredients.length) { %>
                      <button
                        type="button"
                        class="frontend-meal-button"
                        data-meal-name="<%= entry.mealName %>"
                        data-ingredients="<%= entry.ingredients.join('||') %>"
                      >
                        <%= entry.mealName %>
                      </button>
                    <% } else { %>
                      <span class="frontend-plain-meal"><%= entry.mealName %></span>
                    <% } %>
                  </span>
                </li>
              <% }) %>
            </ul>
          </article>
        <% }) %>
      </section>
    </main>

    <dialog id="ingredientsDialog" class="ingredients-dialog frontend-ingredients-dialog">
      <h3 id="ingredientsTitle"></h3>
      <ul id="ingredientsList"></ul>
      <form method="dialog">
        <button class="button secondary">Stäng</button>
      </form>
    </dialog>

    <script>
      const dialog = document.getElementById('ingredientsDialog');
      const title = document.getElementById('ingredientsTitle');
      const list = document.getElementById('ingredientsList');
      const toggle = document.getElementById('themeToggle');

      function getTheme() {
        return document.documentElement.getAttribute('data-theme') || 'light';
      }

      function applyTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        const isDark = theme === 'dark';
        toggle.textContent = isDark ? '☀️ Ljust läge' : '🌙 Mörkt läge';
      }

      applyTheme(getTheme());

      toggle.addEventListener('click', () => {
        const nextTheme = getTheme() === 'dark' ? 'light' : 'dark';
        localStorage.setItem('matschema-theme', nextTheme);
        applyTheme(nextTheme);
      });

      const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      mediaQuery.addEventListener('change', (event) => {
        if (localStorage.getItem('matschema-theme')) {
          return;
        }
        applyTheme(event.matches ? 'dark' : 'light');
      });

      dialog.addEventListener('click', (event) => {
        const rect = dialog.getBoundingClientRect();
        const clickedInDialog =
          event.clientX >= rect.left &&
          event.clientX <= rect.right &&
          event.clientY >= rect.top &&
          event.clientY <= rect.bottom;

        if (!clickedInDialog) {
          dialog.close();
        }
      });

      document.querySelectorAll('.frontend-meal-button').forEach((button) => {
        button.addEventListener('click', () => {
          const mealName = button.dataset.mealName || 'Måltid';
          const ingredientsRaw = button.dataset.ingredients || '';
          const ingredients = ingredientsRaw.split('||').filter(Boolean);

          title.textContent = `Ingredienser: ${mealName}`;
          list.innerHTML = ingredients.map((item) => `<li>${item}</li>`).join('');
          dialog.showModal();
        });
      });
    </script>
  </body>
</html>
