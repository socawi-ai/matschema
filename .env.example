# Runtime
NODE_ENV=production
PORT=3000

# Security
# Set a long random value (at least 32+ chars)
SESSION_SECRET=replace-with-a-long-random-secret

# Behind HTTPS reverse proxy (recommended online defaults)
COOKIE_SECURE=true
FORCE_HTTPS=true

# Allow iframe embedding only from specific origins (comma-separated).
# Example: EMBED_ALLOWED_ORIGINS=https://homeassistant.example.com
# Leave empty to block iframe embedding.
EMBED_ALLOWED_ORIGINS=

# First-run bootstrap account creation
AUTO_BOOTSTRAP_ADMIN=false
DEFAULT_ADMIN_USERNAME=admin
# Leave empty to auto-generate on first run (only shown in non-production logs)
DEFAULT_ADMIN_PASSWORD=
