# Runtime
NODE_ENV=development
PORT=3000

# Security
# In production, set a long random value (at least 32+ chars)
SESSION_SECRET=replace-with-a-long-random-secret

# Set true only when app is behind HTTPS
COOKIE_SECURE=false

# First-run bootstrap (default: true in development, false in production)
AUTO_BOOTSTRAP_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin@matschema.local
# Leave empty to auto-generate a temporary password on first run (development only shown in logs)
DEFAULT_ADMIN_PASSWORD=
